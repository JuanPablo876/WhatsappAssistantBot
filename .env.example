# ─── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3005

# ─── Authentication (Local) ─────────────────────────────
JWT_SECRET=dev-secret-change-this-in-production-use-32-chars-min

# ─── AI Provider ─────────────────────────────────────────
# Provider: "openai" (default) or "ollama" (free, local, no API key needed)
AI_PROVIDER=openai

# OpenAI settings (only when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key

# Ollama settings (when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model name - depends on provider:
# OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# Ollama: llama3.2, qwen3.5:9b, mistral, gemma3:4b
AI_MODEL=gpt-4o-mini

# ─── Google Calendar (OAuth 2.0) ────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project, enable "Google Calendar API"
# 3. Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:3005/api/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── WhatsApp Channel ───────────────────────────────────
# Options: "baileys" (free, local dev) or "cloud-api" (Meta official)
WHATSAPP_CHANNEL=baileys
WHATSAPP_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=my-verify-token

# ─── Voice (optional) ───────────────────────────────────
# ElevenLabs: only needed if using ElevenLabs as voice provider
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ─── Twilio Phone Calls (optional, Pro plan) ────────────
# 1. Go to https://console.twilio.com
# 2. Copy Account SID and Auth Token from dashboard
# 3. Buy a phone number with Voice capability
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
# Webhook base URL for incoming calls (your domain or ngrok)
TWILIO_WEBHOOK_URL=https://iatransmisor.com

# ─── Concierge Service (external bookings) ──────────────
# Google Places API for searching external businesses (spas, restaurants, etc.)
# 1. Go to https://console.cloud.google.com
# 2. Enable "Places API" and "Places API (New)"
# 3. APIs & Services → Credentials → Create API Key
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ─── Search Providers (for web search & business lookup) ──
# Brave Search API (RECOMMENDED - generous free tier: 2000 queries/month)
# 1. Go to https://brave.com/search/api/
# 2. Sign up for free API access
# 3. Copy your API key
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# Google Custom Search (alternative to Brave)
# 1. Go to https://programmablesearchengine.google.com/
# 2. Create a search engine, get the Search Engine ID (cx)
# 3. Enable "Custom Search API" in Google Cloud Console
# 4. Create an API key with Custom Search access
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-cx-id

# ─── Database ───────────────────────────────────────────
DATABASE_URL=file:./dev.db
