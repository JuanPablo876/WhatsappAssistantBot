generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// USERS (Local authentication - Admin/User roles)
// ═══════════════════════════════════════════════════════════

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?  // bcrypt hashed — null for Google-only accounts
  name          String
  role          Role     @default(BUSINESS_OWNER)
  avatarUrl     String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  
  // Google OAuth
  googleId      String?  @unique // Google sub ID for OAuth login
  
  // WhatsApp phone for admin routing (with country code, e.g., "5213318888888")
  phone              String?          @unique // Admin users with this phone get routed based on agentMode
  whatsappAgentMode  WhatsAppAgentMode @default(SECRET_AGENT) // Which agent handles WhatsApp messages from this phone
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A user can own multiple tenants (businesses)
  tenants Tenant[]

  // Admin agent relations
  skillsCreated     AgentSkill[]         @relation("SkillsCreated")
  skillsUpdated     AgentSkill[]         @relation("SkillsUpdated")
  agentSessions     AdminAgentSession[]
  agentAuditLogs    AdminAgentAuditLog[]
}

// Which agent handles WhatsApp messages for admin users
enum WhatsAppAgentMode {
  SECRET_AGENT  // Route to Admin Secret Agent (research, skills, admin tools)
  TENANT_BOT    // Route to regular tenant bot (test as if you were a customer)
}

enum Role {
  ADMIN           // System administrator: manages all users, tenants, settings
  BUSINESS_OWNER  // Client who subscribes: manages their own tenants/businesses
}

// Note: End customers who message via WhatsApp are stored as Contacts (see below)
// They interact through the WhatsApp bot, not through this UI

// ═══════════════════════════════════════════════════════════
// TENANTS (Business configurations - one per WhatsApp number)
// ═══════════════════════════════════════════════════════════

model Tenant {
  id       String @id @default(cuid())
  userId   String // Owner of this tenant
  name     String // Business name
  
  // Owner notification phone (with country code, e.g., "5213318888888")
  // Bot will notify this number about new appointments, messages, etc.
  ownerPhone String?
  
  // Google OAuth tokens for Calendar integration
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  googleCalendarId   String?

  // Subscription
  plan              Plan      @default(FREE)
  stripeCustomerId  String?
  subscriptionId    String?
  
  // Onboarding
  onboardingComplete Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile?
  whatsappConfig  WhatsappConfig?
  voiceConfig     VoiceConfig?
  contacts        Contact[]
  conversations   Conversation[]
  appointments    Appointment[]
  serviceTypes    ServiceType[]
  timeOffs        TimeOff[]
  usageLogs       UsageLog[]
  reminderJobs    ReminderJob[]
  callSessions    CallSession[]

  @@index([userId])
}

enum Plan {
  FREE       // Trial: limited messages/month
  BASIC      // Text chat only
  PRO        // Text + Voice (ElevenLabs) + Calls
  ENTERPRISE // Custom
}

// ═══════════════════════════════════════════════════════════
// BUSINESS PROFILE (from onboarding wizard)
// ═══════════════════════════════════════════════════════════

model BusinessProfile {
  id          String @id @default(cuid())
  tenantId    String @unique
  
  // Step 1: Business description (user input)
  businessName String @default("")
  businessType String @default("")  // e.g., "dental clinic", "salon", "consulting"
  description  String @default("")  // Free-text from onboarding chat/form
  services     String? // Comma-separated services offered
  
  // Step 2: AI-generated system prompt (from description)
  systemPrompt  String @default("")   // Generated by AI from the description
  promptVersion Int    @default(1)    // Track prompt iterations
  
  // Step 3: Schedule settings
  timezone       String @default("America/New_York")
  slotDuration   Int    @default(30)      // minutes
  openTime       String @default("09:00") // HH:mm format
  closeTime      String @default("17:00") // HH:mm format
  workingDays    String @default("Mon,Tue,Wed,Thu,Fri") // CSV day names
  maxAdvanceDays Int    @default(30)
  
  // Step 4: Behavior settings
  language        String @default("en")  // Default response language
  tone            String @default("friendly") // friendly, professional, casual
  reminderMinutes Int    @default(60)
  welcomeMessage  String @default("")  // First message to new contacts
  
  // Reminder/notification settings
  reminderLeadMinutes  String @default("[60]") // JSON array, e.g., [60, 1440] for 1hr + 1day before
  reminderChannels     String @default("[\"WHATSAPP\"]") // JSON array of enabled ReminderChannel values
  quietHoursStart      String? // HH:mm — don't send reminders before this time
  quietHoursEnd        String? // HH:mm — don't send reminders after this time
  emailProvider        String? // "sendgrid" or null
  emailApiKey          String? // Encrypted reference for SendGrid key
  emailFromAddress     String? // Sender email address
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// WHATSAPP CONFIGURATION (per tenant)
// ═══════════════════════════════════════════════════════════
// 
// Three modes for phone/WhatsApp integration:
// 
// 1. RENT_NUMBER - We buy a number from Twilio, assign to tenant
//    - Uses OUR Twilio credentials from .env (they don't need any)
//    - platformPhoneNumberId links to PlatformPhoneNumber
//    - Webhooks route based on phone number lookup
// 
// 2. BAILEYS - Free WhatsApp Web connection
//    - No external credentials needed
//    - Session stored in baileysSessionData
// 
// 3. BYOP_TWILIO / BYOP_META - Bring Your Own Phone
//    - Client provides THEIR credentials (stored ENCRYPTED)
//    - We use their credentials when handling their webhooks
// 
// ═══════════════════════════════════════════════════════════

model WhatsappConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  
  // Phone setup type (how the user chose to get their number)
  setupType PhoneSetupType @default(BAILEYS)
  
  // Channel type
  channel  WhatsappChannel @default(CLOUD_API)
  
  // ─── For RENT_NUMBER setup ───────────────────────────────
  // Links to the PlatformPhoneNumber we assigned to this tenant
  // No credentials needed - we use OUR Twilio account
  platformPhoneNumberId String? // FK to PlatformPhoneNumber.id
  
  // ─── For BYOP_META setup (Cloud API) ─────────────────────
  // Client's own Meta Business credentials (ENCRYPTED in database)
  phoneNumberId   String? // Meta Phone Number ID
  accessToken     String? // Meta Access Token (ENCRYPTED)
  businessId      String? // Meta Business Account ID  
  verifyToken     String? // Webhook verify token
  webhookSecret   String? // Webhook signature secret (ENCRYPTED)
  
  // ─── For BYOP_TWILIO setup ───────────────────────────────
  // Client's own Twilio credentials (ENCRYPTED in database)
  twilioAccountSid  String? // Twilio Account SID (not sensitive, but stored for reference)
  twilioAuthToken   String? // Twilio Auth Token (ENCRYPTED - very sensitive!)
  twilioPhoneNumber String? // Client's Twilio phone number
  
  // ─── For BAILEYS setup ───────────────────────────────────
  baileysSessionData String? // Serialized auth state
  baileysConnected   Boolean @default(false)
  
  // Status
  isActive  Boolean @default(false)
  lastPing  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// How user chose to set up their phone number
enum PhoneSetupType {
  RENT_NUMBER   // Rent from us (we buy from Twilio, takes a few days)
  BAILEYS       // Free, use WhatsApp Web via QR code
  BYOP_TWILIO   // Bring Your Own Phone via Twilio
  BYOP_META     // Bring Your Own Phone via Meta Business (Cloud API)
}

enum WhatsappChannel {
  CLOUD_API
  BAILEYS
}

// ═══════════════════════════════════════════════════════════
// PHONE NUMBER RENTAL REQUESTS (Admin notification system)
// ═══════════════════════════════════════════════════════════

model PhoneRentalRequest {
  id       String @id @default(cuid())
  tenantId String
  
  // Request details
  countryCode     String            // ISO country code (e.g., "MX", "US")
  preferredArea   String?           // Preferred area code (e.g., "33" for Guadalajara)
  purpose         String?           // Brief description of use case
  
  // Status tracking
  status          RentalRequestStatus @default(PENDING)
  adminNotes      String?           // Notes from admin during processing
  
  // Assigned number (once fulfilled)
  assignedNumber  String?           // The Twilio number purchased
  twilioNumberSid String?           // Twilio Phone Number SID
  monthlyPrice    Float?            // Monthly cost in USD
  
  // Timestamps
  requestedAt     DateTime          @default(now())
  processedAt     DateTime?         // When admin started processing
  fulfilledAt     DateTime?         // When number was assigned
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([tenantId])
  @@index([status])
}

enum RentalRequestStatus {
  PENDING       // Waiting for admin to process
  PROCESSING    // Admin is purchasing the number
  FULFILLED     // Number assigned and active
  REJECTED      // Request was rejected (with reason in adminNotes)
  CANCELLED     // User cancelled the request
}

// ═══════════════════════════════════════════════════════════
// PLATFORM PHONE NUMBERS (Numbers WE own and rent to clients)
// ═══════════════════════════════════════════════════════════

model PlatformPhoneNumber {
  id          String @id @default(cuid())
  
  // Twilio phone number details (from our account)
  phoneNumber String @unique // E.164 format (e.g., "+523321011949")
  twilioSid   String @unique // Twilio Phone Number SID (PN...)
  
  // Location info
  countryCode String // ISO code (e.g., "MX", "US")
  areaCode    String? // Area code (e.g., "33" for Guadalajara)
  friendlyName String? // Human-readable name
  
  // Assignment
  tenantId    String? // Null = available, set = assigned to this tenant
  assignedAt  DateTime?
  
  // Capabilities
  voiceEnabled Boolean @default(true)
  smsEnabled   Boolean @default(true)
  
  // Billing
  monthlyPrice Float @default(0) // What we charge the client
  twilioCost   Float @default(0) // What Twilio charges us
  
  // Status
  status PlatformNumberStatus @default(AVAILABLE)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([tenantId])
  @@index([countryCode])
  @@index([status])
}

enum PlatformNumberStatus {
  AVAILABLE    // Ready to assign
  ASSIGNED     // Currently assigned to a tenant
  SUSPENDED    // Temporarily disabled (billing issue, etc.)
  RELEASING    // Being released back to Twilio
}

// ═══════════════════════════════════════════════════════════
// VOICE CONFIGURATION (ElevenLabs or OpenAI TTS - PRO tier)
// ═══════════════════════════════════════════════════════════

model VoiceConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  
  enabled       Boolean @default(false)
  provider      String  @default("openai") // "elevenlabs" or "openai"
  
  // ElevenLabs settings
  apiKey        String? // Tenant's own ElevenLabs API key (or use ours with metering)
  voiceId       String? // Selected ElevenLabs voice
  voiceName     String? // Display name
  model         String  @default("eleven_multilingual_v2")
  stability     Float   @default(0.5)
  similarityBoost Float @default(0.75)
  
  // OpenAI TTS settings
  openaiVoice   String  @default("nova") // alloy, echo, fable, onyx, nova, shimmer
  openaiModel   String  @default("tts-1") // tts-1 or tts-1-hd
  openaiSpeed   Float   @default(1.0) // 0.25 to 4.0
  
  // Twilio Phone Call settings
  callsEnabled     Boolean @default(false)
  callWebhookUrl   String?
  callGreeting     String? // Custom greeting for inbound calls
  callSystemPrompt String? // Custom system prompt for call AI
  callLanguage     String  @default("en-US") // BCP-47 language code
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callLogs CallLog[]
}

// ═══════════════════════════════════════════════════════════
// CALL LOGS (Twilio phone call records)
// ═══════════════════════════════════════════════════════════

model CallLog {
  id       String @id @default(cuid())
  tenantId String
  
  callSid     String  @unique // Twilio Call SID
  direction   String  // INBOUND or OUTBOUND
  from        String  // Caller phone number
  to          String  // Recipient phone number
  status      String  // initiated, ringing, answered, completed, failed, busy, no-answer
  duration    Int?    // Call duration in seconds
  transcript  String? // JSON conversation transcript
  recordingUrl String?
  recordingSid String?
  
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime @default(now())
  
  voiceConfig VoiceConfig? @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// CONTACTS (end-users who message the business)
// ═══════════════════════════════════════════════════════════

model Contact {
  id       String @id @default(cuid())
  tenantId String
  
  phone    String
  name     String?
  email    String?
  timezone String @default("America/New_York")
  language String @default("en")
  metadata String @default("{}") // JSON for custom fields
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reminder preferences
  reminderOptOut    Boolean @default(false)
  preferredChannel  String? // Preferred reminder channel override

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  appointments  Appointment[]
  reminderJobs  ReminderJob[]
  callSessions  CallSession[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════
// CONVERSATIONS
// ═══════════════════════════════════════════════════════════

model Conversation {
  id        String @id @default(cuid())
  tenantId  String
  contactId String
  
  status   ConversationStatus @default(ACTIVE)
  channel  String             @default("whatsapp") // whatsapp, voice, web
  context  String?            // JSON conversation context
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([tenantId])
  @@index([contactId])
  @@index([status])
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

// ═══════════════════════════════════════════════════════════
// MESSAGES
// ═══════════════════════════════════════════════════════════

model Message {
  id             String @id @default(cuid())
  conversationId String
  
  role       String  // user, assistant, system, tool
  content    String
  toolCalls  String? // JSON
  toolCallId String?
  
  // Voice messages
  audioUrl   String?
  duration   Float?  // seconds
  
  tokenCount Int?
  createdAt  DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════
// SERVICE TYPES (appointment types with custom durations)
// ═══════════════════════════════════════════════════════════

model ServiceType {
  id          String  @id @default(cuid())
  tenantId    String
  name        String       // "Haircut", "Coloring", "Consultation"
  description String?
  duration    Int          // minutes
  price       Float?       // optional price
  color       String?      // UI accent color hex
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════
// ADMIN AGENT SKILLS (knowledge base - NOT executable code)
// ═══════════════════════════════════════════════════════════

model AgentSkill {
  id                String        @id @default(cuid())
  title             String
  category          String        @default("general") // e.g., "api-integration", "workflow", "product-knowledge"
  tags              String        @default("[]") // JSON array of tag strings
  summary           String        // Short description of what this skill covers
  workflowGuidance  String        @default("") // Step-by-step guidance for the agent to follow
  implementationNotes String      @default("") // Notes for developers to convert to native code
  codeSnippets      String        @default("[]") // JSON array of vetted code snippets (knowledge, not runtime)
  
  // Review lifecycle
  reviewStatus      SkillReviewStatus @default(PROPOSED)
  deliveryMode      SkillDeliveryMode @default(KNOWLEDGE)
  isEnabled         Boolean       @default(true) // Proposed skills can still be usable immediately
  
  // Usage tracking
  priority          Int           @default(0) // Higher = more important
  usageCount        Int           @default(0)
  lastUsedAt        DateTime?
  
  // Audit
  createdByUserId   String
  updatedByUserId   String?
  lastReviewedAt    DateTime?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  createdBy  User              @relation("SkillsCreated", fields: [createdByUserId], references: [id])
  updatedBy  User?             @relation("SkillsUpdated", fields: [updatedByUserId], references: [id])
  sources    AgentSkillSource[]

  @@index([category])
  @@index([reviewStatus])
  @@index([isEnabled])
  @@index([lastUsedAt])
  @@index([priority])
}

enum SkillReviewStatus {
  PROPOSED
  REVIEWED
  REJECTED
  ARCHIVED
}

enum SkillDeliveryMode {
  KNOWLEDGE    // Usable as knowledge and guidance
  NATIVE_TOOL  // Has been promoted to a native code implementation
}

model AgentSkillSource {
  id          String @id @default(cuid())
  skillId     String
  url         String
  title       String @default("")
  sourceType  String @default("web") // "web", "api-docs", "github", "manual"
  snippet     String @default("") // Curated excerpt, NOT raw HTML
  contentHash String @default("") // For deduplication
  fetchedAt   DateTime @default(now())

  skill AgentSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([contentHash])
}

// ═══════════════════════════════════════════════════════════
// ADMIN AGENT SESSIONS & AUDIT
// ═══════════════════════════════════════════════════════════

model AdminAgentSession {
  id        String @id @default(cuid())
  userId    String
  title     String @default("New conversation")
  messages  String @default("[]") // JSON array of AIMessage
  summary   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AdminAgentAuditLog[]

  @@index([userId])
  @@index([createdAt])
}

model AdminAgentAuditLog {
  id          String @id @default(cuid())
  sessionId   String
  userId      String
  toolName    String
  inputSummary  String @default("") // Sanitized summary of tool input
  outputSummary String @default("") // Sanitized summary of tool output
  durationMs  Int?
  
  createdAt DateTime @default(now())

  session AdminAgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([toolName])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════
// REMINDER JOBS & HISTORY
// ═══════════════════════════════════════════════════════════

model ReminderJob {
  id            String        @id @default(cuid())
  tenantId      String
  appointmentId String
  contactId     String
  channel       ReminderChannel
  scheduledFor  DateTime
  status        ReminderStatus @default(PENDING)
  attempts      Int           @default(0)
  lastError     String?
  payload       String?       // JSON payload with contact/appointment details for sending

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  contact     Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  history     ReminderHistory[]

  @@index([tenantId])
  @@index([status, scheduledFor])
  @@index([appointmentId])
}

enum ReminderChannel {
  WHATSAPP
  EMAIL
  VOICE_CALL
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model ReminderHistory {
  id         String @id @default(cuid())
  jobId      String
  channel    ReminderChannel
  status     ReminderStatus
  deliveredAt DateTime?
  errorDetail String?

  createdAt DateTime @default(now())

  job ReminderJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ═══════════════════════════════════════════════════════════
// CALL SESSIONS (future realtime call telemetry)
// ═══════════════════════════════════════════════════════════

model CallSession {
  id          String  @id @default(cuid())
  tenantId    String
  contactId   String?
  callId      String? // External provider call ID
  direction   String  @default("inbound") // "inbound" or "outbound"
  status      String  @default("initiated") // initiated, ringing, in-progress, completed, failed
  transcript  String  @default("[]") // JSON array of transcript turns
  latencyMs   String  @default("{}") // JSON latency metrics per turn
  startedAt   DateTime @default(now())
  endedAt     DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([startedAt])
}

// ═══════════════════════════════════════════════════════════
// TIME OFF / BLOCKED TIME (vacations, holidays, breaks)
// ═══════════════════════════════════════════════════════════

model TimeOff {
  id       String @id @default(cuid())
  tenantId String

  title       String        // "Summer Vacation", "Lunch Break", "Holiday"
  reason      String?       // Optional description / notes
  allDay      Boolean @default(true) // true = whole day(s), false = specific hours
  startDate   DateTime      // Start date (or date+time if !allDay)
  endDate     DateTime      // End date (or date+time if !allDay)
  recurring   Boolean @default(false) // Reserved for future: weekly recurring blocks
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([startDate, endDate])
}

// ═══════════════════════════════════════════════════════════
// APPOINTMENTS
// ═══════════════════════════════════════════════════════════

model Appointment {
  id       String @id @default(cuid())
  tenantId String
  contactId String
  serviceTypeId String? // optional link to service type
  
  calendarEventId String? // Google Calendar event ID
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(CONFIRMED)
  reminderSent    Boolean           @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  serviceType ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  reminders   ReminderJob[]

  @@index([tenantId])
  @@index([contactId])
  @@index([status])
  @@index([startTime])
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

// ═══════════════════════════════════════════════════════════
// USAGE TRACKING (for billing & rate limiting)
// ═══════════════════════════════════════════════════════════

model UsageLog {
  id       String @id @default(cuid())
  tenantId String
  
  type     UsageType
  count    Int       @default(1)
  metadata String?   // JSON
  
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
}

enum UsageType {
  MESSAGE_IN
  MESSAGE_OUT
  AI_TOKENS
  VOICE_CHARACTERS  // ElevenLabs characters used
  VOICE_CALL_MINUTES
  APPOINTMENT_CREATED
}
