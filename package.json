{
  "name": "whatsapp-assistant-bot",
  "version": "2.0.0",
  "private": true,
  "description": "Desktop AI WhatsApp assistant with multi-tenant support, Google Calendar, voice support, and admin panel",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"next dev -p 3005\" \"npm run electron:dev\"",
    "dev:web": "next dev -p 3005",
    "build": "next build",
    "start": "next start -p 3005",
    "lint": "next lint",
    "electron:dev": "tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && electron-builder",
    "electron:pack": "npm run build && tsc -p electron/tsconfig.json && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "bot:worker": "tsx src/lib/bot/worker.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/qrcode": "^1.5.6",
    "@whiskeysockets/baileys": "^6.7.16",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "dayjs": "^1.11.13",
    "electron-updater": "^6.8.3",
    "elevenlabs": "^1.52.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.35.1",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.474.0",
    "next": "^15.2.0",
    "node-cron": "^3.0.3",
    "openai": "^4.85.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "twilio": "^5.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.0",
    "prisma": "^6.4.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.whatsapp-assistant.bot",
    "productName": "WhatsApp Assistant Bot",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "standalone/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "prisma",
        "to": "standalone/prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts",
        "to": "standalone/scripts",
        "filter": [
          "**/*.js"
        ]
      },
      {
        "from": "node_modules/better-sqlite3",
        "to": "standalone/node_modules/better-sqlite3",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/bindings",
        "to": "standalone/node_modules/bindings",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/file-uri-to-path",
        "to": "standalone/node_modules/file-uri-to-path",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".env",
        "to": "standalone/.env"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "JuanPablo876",
      "repo": "WhatsappAssistantBot",
      "releaseType": "release",
      "private": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
